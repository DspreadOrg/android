<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data>
        <variable
            name="fragment"
            type="com.dspread.pos.ui.mifare.ClassicFragment" />
    </data>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/white">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Step 1: Power Control with Activate/Deactivate Buttons -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="① Power Control (NFC)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/red_color"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Please tap card when activating"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/activateBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/mifare_active"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:background="@drawable/button_red"
                    android:layout_marginEnd="5dp" />
                <Button
                    android:id="@+id/deactivateBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/mifare_deactive"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:background="@drawable/button_red"
                    android:layout_marginStart="5dp"
                    android:enabled="false" />
            </LinearLayout>

            <TextView
                android:id="@+id/powerStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: Not Activated"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:layout_marginBottom="16dp"
                android:gravity="center" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/light_gray"
                android:layout_marginBottom="16dp" />

            <!-- Step 2: APDU Commands -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="② APDU Commands"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/red_color"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Desfire cards use APDU commands for all operations. Enter your APDU command below:"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:layout_marginBottom="12dp" />

            <!-- APDU Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="APDU Command:"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="4dp" />
                <EditText
                    android:id="@+id/apduText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="00A4040007A0000002471010"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:background="@drawable/edittext_white"
                    android:padding="8dp"
                    android:fontFamily="monospace"
                    android:minHeight="48dp" />
            </LinearLayout>

            <Button
                android:id="@+id/sendApduBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send APDU"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:background="@drawable/button_red"
                android:enabled="false"
                android:layout_marginBottom="16dp" />

            <!-- Result Section -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/light_gray"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Result:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/red_color"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/resultText"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:hint="APDU responses will be displayed here..."
                android:textSize="14sp"
                android:textColor="@color/black"
                android:background="@drawable/edittext_white"
                android:gravity="top"
                android:scrollbars="vertical"
                android:padding="8dp"
                />

        </LinearLayout>
    </ScrollView>

</layout>
