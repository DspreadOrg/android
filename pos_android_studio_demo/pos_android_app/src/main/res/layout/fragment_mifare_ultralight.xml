<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data>
        <variable
            name="fragment"
            type="com.dspread.pos.ui.mifare.ClassicFragment" />
    </data>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/white">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Step 1: Power Control with Activate/Deactivate Buttons -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="① Power Control"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/red_color"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Please tap card when activating"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/activateBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/mifare_active"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:background="@drawable/button_red"
                    android:layout_marginEnd="5dp" />
                <Button
                    android:id="@+id/deactivateBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/mifare_deactive"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:background="@drawable/button_red"
                    android:layout_marginStart="5dp"
                    android:enabled="false" />
            </LinearLayout>

            <TextView
                android:id="@+id/powerStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: Not Activated"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:layout_marginBottom="16dp"
                android:gravity="center" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/light_gray"
                android:layout_marginBottom="16dp" />

            <!-- Step 2: Fast Read Operations (Ultralight specific) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="② Fast Read Operations"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/red_color"
                android:layout_marginBottom="12dp" />

            <!-- Start Page -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start Page:"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_gravity="center_vertical" />
                <EditText
                    android:id="@+id/startPageText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="0"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:background="@drawable/edittext_white"
                    android:padding="8dp"
                    android:inputType="number" />
            </LinearLayout>

            <!-- End Page -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="End Page:"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_gravity="center_vertical" />
                <EditText
                    android:id="@+id/endPageText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="3"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:background="@drawable/edittext_white"
                    android:padding="8dp"
                    android:inputType="number" />
            </LinearLayout>

            <Button
                android:id="@+id/fastReadBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fast Read Pages"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:background="@drawable/button_red"
                android:enabled="false"
                android:layout_marginBottom="16dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/light_gray"
                android:layout_marginBottom="16dp" />

            <!-- Step 3: Data Operations -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="③ Data Operations"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/red_color"
                android:layout_marginBottom="12dp" />

            <!-- Operation Type RadioGroup -->
            <RadioGroup
                android:id="@+id/operationTypeRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <RadioButton
                    android:id="@+id/blockValueRadio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Block Value"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:checked="true" />
                <RadioButton
                    android:id="@+id/financialValueRadio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Financial Value"
                    android:textSize="14sp"
                    android:textColor="@color/black" />
            </RadioGroup>

            <!-- Block Value Operations -->
            <LinearLayout
                android:id="@+id/blockValueLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Block Address -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Block Address:"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:layout_gravity="center_vertical" />
                    <EditText
                        android:id="@+id/blockValueAddressText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="04"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:background="@drawable/edittext_white"
                        android:padding="8dp" />
                </LinearLayout>

                <!-- Write Data -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Write Data:"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:layout_gravity="center_vertical" />
                    <EditText
                        android:id="@+id/blockWriteDataText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="A5A5B6B6"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:background="@drawable/edittext_white"
                        android:padding="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <Button
                        android:id="@+id/readBlockBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Read Block"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:background="@drawable/button_red"
                        android:layout_marginEnd="5dp"
                        android:enabled="false" />
                    <Button
                        android:id="@+id/writeBlockBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Write Block"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:background="@drawable/button_red"
                        android:layout_marginStart="5dp"
                        android:enabled="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- Financial Value Operations -->
            <LinearLayout
                android:id="@+id/financialValueLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Block Address -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Block Address:"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:layout_gravity="center_vertical" />
                    <EditText
                        android:id="@+id/financialBlockAddressText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="04"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:background="@drawable/edittext_white"
                        android:padding="8dp" />
                </LinearLayout>

                <!-- Value -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Value:"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:layout_gravity="center_vertical" />
                    <EditText
                        android:id="@+id/financialValueText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="100"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:background="@drawable/edittext_white"
                        android:padding="8dp"
                        android:inputType="number" />
                </LinearLayout>

                <!-- Operation Type and Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <Spinner
                        android:id="@+id/financialOperationSpinner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp" />
                    <Button
                        android:id="@+id/operateValueBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Operate Value"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:background="@drawable/button_red"
                        android:layout_marginStart="5dp"
                        android:enabled="false" />
                </LinearLayout>

                <!-- Read/Write Value Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <Button
                        android:id="@+id/readValueBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Read Value"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:background="@drawable/button_red"
                        android:layout_marginEnd="5dp"
                        android:enabled="false" />
                    <Button
                        android:id="@+id/writeValueBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Write Value"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:background="@drawable/button_red"
                        android:layout_marginStart="5dp"
                        android:enabled="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- Result Section -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/light_gray"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Result:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/red_color"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/resultText"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:hint="Operation results will be displayed here..."
                android:textSize="14sp"
                android:textColor="@color/black"
                android:background="@drawable/edittext_white"
                android:gravity="top"
                android:scrollbars="vertical"
                android:padding="8dp" />

        </LinearLayout>
    </ScrollView>

</layout>
